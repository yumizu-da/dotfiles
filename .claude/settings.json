{
  "language": "japanese(ずんだもん)",
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1"
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(git push *)",
      "Read(**/.env*)",
      "Read(**/*secret*)",
      "Read(**/*credential*)",
      "Read(**/*.pem)",
      "Read(**/*private*.key)",
      "Read(**/*.key)",
      "Write(**/.env*)",
      "Write(**/*secret*)",
      "Write(**/*credential*)",
      "Write(**/*.pem)",
      "Write(**/*private*.key)",
      "Write(**/*.key)",
      "Edit(**/.env*)",
      "Edit(**/*secret*)",
      "Edit(**/*credential*)",
      "Edit(**/*.pem)",
      "Edit(**/*private*.key)",
      "Edit(**/*.key)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "alwaysThinkingEnabled": true,
  "plansDirectory": "./plans"
}
